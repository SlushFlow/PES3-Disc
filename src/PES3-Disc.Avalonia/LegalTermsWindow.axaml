<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PES3Disc.Avalonia.LegalTermsWindow"
        Title="Legal notice — PES3-Disc"
        Width="500" Height="440"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#0F1419">
  <StackPanel Margin="24" Spacing="12">
    <TextBlock Text="Before using decrypt or copy" FontSize="18" FontWeight="Bold" Foreground="#E8EDF4"/>
    <TextBlock Classes="muted" TextWrapping="Wrap"
               Text="PES3-Disc is not legal advice. You are responsible for compliance in your country."/>
    <Border Background="#1A2332" CornerRadius="8" Padding="16">
      <StackPanel Spacing="10">
        <CheckBox x:Name="OwnDiscCheck" Foreground="#E8EDF4"
                  Content="I own the physical PS3 disc I use with decrypt or copy features."/>
        <CheckBox x:Name="NoRedistributeCheck" Foreground="#E8EDF4"
                  Content="I will not share, upload, or redistribute decrypted or copied game files."/>
        <CheckBox x:Name="ComplyLawCheck" Foreground="#E8EDF4"
                  Content="I understand PES3-Disc does not grant copyright or circumvention rights; I follow laws in my region."/>
        <Button Classes="secondary" Content="Open LEGAL.md" Click="OpenLegal_Click" HorizontalAlignment="Left"/>
        <Button Classes="secondary" Content="Open user legal guide" Click="OpenGuide_Click" HorizontalAlignment="Left"/>
      </StackPanel>
    </Border>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button Classes="secondary" Content="Cancel" Click="Cancel_Click"/>
      <Button x:Name="AcceptButton" Classes="primary" Content="I agree — continue" IsEnabled="False" Click="Accept_Click"/>
    </StackPanel>
  </StackPanel>
</Window>
