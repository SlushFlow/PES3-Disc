<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PES3Disc.Avalonia.SettingsWindow"
        Title="Settings"
        Width="560" Height="520"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#0F1419">
  <ScrollViewer>
    <StackPanel Margin="24" Spacing="12">
      <TextBlock Text="Settings" FontSize="22" FontWeight="Bold" Foreground="#E8EDF4"/>
      <TextBlock Text="RPCS3 path" Classes="muted"/>
      <TextBox x:Name="Rpcs3Box"/>
      <Button Classes="secondary" Content="Browse…" Click="Browse_Click" HorizontalAlignment="Left"/>
      <TextBlock Text="Storage mode" Classes="muted"/>
      <ComboBox x:Name="StorageModeCombo"/>
      <TextBlock x:Name="StorageModeHint" Classes="muted" TextWrapping="Wrap"/>
      <CheckBox x:Name="EjectCleanupCheck" Content="Remove sessions when disc is ejected" Foreground="#E8EDF4"/>
      <TextBlock Text="Max local SSD for disc-assisted overlay (MB)" Classes="muted"/>
      <TextBox x:Name="OverlayMbBox" Width="100" HorizontalAlignment="Left"/>
      <TextBlock Text="Custom library/cache folder (optional)" Classes="muted"/>
      <TextBox x:Name="CachePathBox"/>
      <CheckBox x:Name="RetailCheck" Content="Offer retail disc decryption" Foreground="#E8EDF4"/>
      <TextBlock Text="Linux dump tool path (optional)" Classes="muted"/>
      <TextBox x:Name="DumpCliBox" Watermark="pes3-disc-dump-linux"/>
      <TextBlock Text="IRD key folder (optional)" Classes="muted"/>
      <TextBox x:Name="IrdDirBox"/>
      <CheckBox x:Name="BackupsCheck" Content="Enable automatic backups" Foreground="#E8EDF4"/>
      <TextBlock Text="Bug report API URL (optional)" Classes="muted"/>
      <TextBox x:Name="BugReportApiBox" Watermark="https://pes3-bugreports.onrender.com"/>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
        <Button Classes="secondary" Content="Cancel" Click="Cancel_Click"/>
        <Button Classes="primary" Content="Save" Click="Save_Click"/>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</Window>
