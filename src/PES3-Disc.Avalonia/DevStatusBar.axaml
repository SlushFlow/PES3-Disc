<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PES3Disc.Avalonia.DevStatusBar">
  <Border Background="#1A2332" BorderBrush="#2A3544" BorderThickness="1"
          CornerRadius="6" Padding="10,6">
    <StackPanel Orientation="Horizontal" Spacing="8">
      <Ellipse x:Name="StatusDot" Width="10" Height="10" VerticalAlignment="Center"/>
      <StackPanel Spacing="2">
        <TextBlock Text="Developer" FontSize="10" Classes="muted"/>
        <TextBlock x:Name="StatusLabel" FontSize="12" Foreground="#E8EDF4"/>
      </StackPanel>
    </StackPanel>
  </Border>
</UserControl>
