<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PES3Disc.Avalonia.ReportBugWindow"
        Title="Report a bug"
        Width="520" Height="420"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#0F1419">
  <Grid Margin="24" RowDefinitions="Auto,Auto,*,Auto,Auto">
    <TextBlock Text="Report a bug" FontSize="22" FontWeight="Bold" Foreground="#E8EDF4"/>
    <TextBlock Grid.Row="1" Text="Short title and description (sent to developers)."
               Classes="muted" TextWrapping="Wrap" Margin="0,8,0,12"/>
    <StackPanel Grid.Row="2" Spacing="4">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Text="Title" Foreground="#E8EDF4"/>
        <TextBlock x:Name="TitleCount" Grid.Column="1" Classes="muted" Text="0/50"/>
      </Grid>
      <TextBox x:Name="TitleBox" MaxLength="50" TextChanged="OnTextChanged"/>
      <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
        <TextBlock Text="Description" Foreground="#E8EDF4"/>
        <TextBlock x:Name="BodyCount" Grid.Column="1" Classes="muted" Text="0/2500"/>
      </Grid>
      <TextBox x:Name="BodyBox" MaxLength="2500" AcceptsReturn="True" TextWrapping="Wrap"
               MinHeight="140" TextChanged="OnTextChanged"/>
    </StackPanel>
    <TextBlock x:Name="StatusText" Grid.Row="3" Classes="muted" TextWrapping="Wrap" Margin="0,12,0,0"/>
    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
      <Button Classes="secondary" Content="Cancel" Click="Cancel_Click"/>
      <Button x:Name="SubmitButton" Classes="primary" Content="Submit" Click="Submit_Click"/>
    </StackPanel>
  </Grid>
</Window>
