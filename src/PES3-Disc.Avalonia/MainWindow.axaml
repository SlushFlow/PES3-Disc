<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:PES3Disc.Avalonia"
        x:Class="PES3Disc.Avalonia.MainWindow"
        Title="PES3-Disc"
        Width="720" Height="640"
        MinWidth="560" MinHeight="480"
        Background="#0A0E12">
  <Grid Margin="20" RowDefinitions="Auto,Auto,*,Auto">
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel>
        <TextBlock Text="PES3-Disc" FontSize="28" FontWeight="Bold" Foreground="#FFFFFF"/>
        <TextBlock x:Name="SubtitleText" Classes="muted" Margin="0,4,0,0"/>
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top">
        <local:DevStatusBar x:Name="DevStatus"/>
        <Button x:Name="ScanButton" Classes="secondary" Content="Scan" Click="Scan_Click"/>
        <Button Classes="secondary" Content="Report bug" Click="ReportBug_Click"/>
        <Button Classes="secondary" Content="Settings" Click="Settings_Click"/>
      </StackPanel>
    </Grid>

    <Border Grid.Row="1" Classes="card" Margin="0,16,0,0" Padding="12">
      <TextBlock x:Name="StatusBanner" TextWrapping="Wrap" Classes="emphasis"/>
    </Border>

    <ScrollViewer Grid.Row="2" Margin="0,8,0,0">
      <StackPanel x:Name="DiscListPanel" Spacing="0"/>
    </ScrollViewer>

    <TextBlock Grid.Row="3" x:Name="FooterText" Classes="muted" FontSize="11"
               TextWrapping="Wrap" Margin="0,12,0,0"/>
  </Grid>
</Window>
