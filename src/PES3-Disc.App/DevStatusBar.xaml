<UserControl x:Class="PES3Disc.App.DevStatusBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Background="#1A2332" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
          CornerRadius="6" Padding="10,6" VerticalAlignment="Center">
    <StackPanel Orientation="Horizontal">
      <Ellipse x:Name="StatusDot" Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center"/>
      <StackPanel>
        <TextBlock Text="Developer" FontSize="10" Foreground="{StaticResource MutedBrush}"/>
        <TextBlock x:Name="StatusLabel" FontSize="12" Foreground="{StaticResource TextBrush}"/>
      </StackPanel>
    </StackPanel>
  </Border>
</UserControl>
