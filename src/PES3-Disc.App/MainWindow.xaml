<Window x:Class="PES3Disc.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PES3-Disc"
        Height="640" Width="720"
        MinHeight="480" MinWidth="560"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,16">
      <StackPanel>
        <TextBlock Text="PES3-Disc" FontSize="28" FontWeight="Bold" Foreground="White"/>
        <TextBlock x:Name="SubtitleText" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
        <local:DevStatusBar x:Name="DevStatus" xmlns:local="clr-namespace:PES3Disc.App" Margin="0,0,12,0"/>
        <Button x:Name="ScanButton" Content="Scan" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="Scan_Click"/>
        <Button Content="Report bug" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="ReportBug_Click"/>
        <Button Content="Settings" Style="{StaticResource SecondaryButton}" Click="Settings_Click"/>
      </StackPanel>
    </Grid>

    <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="12">
      <TextBlock x:Name="StatusBanner" TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
    </Border>

    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,4,0,0">
      <StackPanel x:Name="DiscListPanel"/>
    </ScrollViewer>

    <TextBlock Grid.Row="3" x:Name="FooterText" FontSize="11" Foreground="{StaticResource MutedBrush}"
               Margin="0,12,0,0" TextWrapping="Wrap"/>
  </Grid>
</Window>
