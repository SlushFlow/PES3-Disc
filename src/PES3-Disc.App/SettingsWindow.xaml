<Window x:Class="PES3Disc.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="560" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
  <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="24">
    <StackPanel>
      <TextBlock Text="Settings" FontSize="22" FontWeight="Bold" Margin="0,0,0,16"/>

      <Border Style="{StaticResource CardBorder}">
        <StackPanel>
          <TextBlock Text="RPCS3" FontWeight="SemiBold"/>
          <Grid Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="Rpcs3Box" Padding="8" Background="#0F1419" Foreground="{StaticResource TextBrush}"
                     BorderBrush="{StaticResource BorderBrush}" IsReadOnly="True"/>
            <Button Grid.Column="1" Content="Browse" Margin="8,0,0,0" Style="{StaticResource SecondaryButton}" Click="Browse_Click"/>
          </Grid>
          <CheckBox x:Name="NoGuiCheck" Content="Launch RPCS3 with --no-gui" Margin="0,12,0,0"
                    Foreground="{StaticResource TextBrush}"/>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource CardBorder}">
        <StackPanel>
          <TextBlock Text="PES3 library (storage)" FontWeight="SemiBold"/>
          <TextBlock Text="Smart hybrid: small SSD session + disc provides bulk; removed on RPCS3 exit or disc eject. Persistent library keeps full decrypts for instant replay."
                     Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" FontSize="12" Margin="0,6,0,0"/>
          <CheckBox x:Name="EjectCleanupCheck" Content="Remove disc-assisted sessions when the disc is ejected" Margin="0,10,0,0"
                    Foreground="{StaticResource TextBrush}" IsChecked="True"/>
          <TextBlock Text="Max local SSD for disc-assisted overlay (MB)" Margin="0,12,0,4" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
          <TextBox x:Name="OverlayMbBox" Padding="8" Background="#0F1419" Foreground="{StaticResource TextBrush}"
                   BorderBrush="{StaticResource BorderBrush}" Width="100" HorizontalAlignment="Left"/>
          <TextBlock Text="Storage mode" Margin="0,12,0,4" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
          <ComboBox x:Name="StorageModeCombo" Padding="8,6" Background="#0F1419" Foreground="{StaticResource TextBrush}"/>
          <TextBlock x:Name="StorageModeHint" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" FontSize="12" Margin="0,6,0,0"/>
          <TextBlock Text="Custom library/cache folder (optional)" Margin="0,12,0,4" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
          <TextBox x:Name="CachePathBox" Padding="8" Background="#0F1419" Foreground="{StaticResource TextBrush}"
                   BorderBrush="{StaticResource BorderBrush}"/>
          <CheckBox x:Name="RetailCheck" Content="Offer retail disc decryption" Margin="0,12,0,0"
                    Foreground="{StaticResource TextBrush}"/>
          <CheckBox x:Name="UnknownCheck" Content="Try decrypt on unknown optical media" Margin="0,8,0,0"
                    Foreground="{StaticResource TextBrush}"/>
          <TextBlock Text="Scan delay (seconds)" Margin="0,12,0,4" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
          <TextBox x:Name="DelayBox" Padding="8" Background="#0F1419" Foreground="{StaticResource TextBrush}"
                   BorderBrush="{StaticResource BorderBrush}" Width="80" HorizontalAlignment="Left"/>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource CardBorder}">
        <StackPanel>
          <TextBlock Text="Retail decrypt" FontWeight="SemiBold"/>
          <TextBlock Text="pes3-disc-dump.exe path (optional)" Margin="0,8,0,4" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
          <TextBox x:Name="DumpCliBox" Padding="8" Background="#0F1419" Foreground="{StaticResource TextBrush}"
                   BorderBrush="{StaticResource BorderBrush}"/>
          <TextBlock Text="IRD key folder (optional)" Margin="0,8,0,4" Foreground="{StaticResource MutedBrush}" FontSize="12"/>
          <TextBox x:Name="IrdDirBox" Padding="8" Background="#0F1419" Foreground="{StaticResource TextBrush}"
                   BorderBrush="{StaticResource BorderBrush}"/>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource CardBorder}">
        <StackPanel>
          <TextBlock Text="Backups" FontWeight="SemiBold"/>
          <CheckBox x:Name="BackupsCheck" Content="Enable automatic backups before cache cleanup" Margin="0,10,0,0"
                    Foreground="{StaticResource TextBrush}"/>
          <CheckBox x:Name="BackupOnLaunchCheck" Content="Also backup DIY discs on every launch" Margin="0,8,0,0"
                    Foreground="{StaticResource TextBrush}"/>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource CardBorder}">
        <StackPanel>
          <TextBlock Text="Windows" FontWeight="SemiBold"/>
          <CheckBox x:Name="StartupCheck" Content="Run at Windows login" Margin="0,10,0,0"
                    Foreground="{StaticResource TextBrush}"/>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource CardBorder}">
        <StackPanel>
          <TextBlock Text="Legal" FontWeight="SemiBold"/>
          <TextBlock x:Name="LegalStatusText" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" FontSize="12" Margin="0,8,0,0"/>
          <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
            <Button Content="Open LEGAL.md" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="OpenLegal_Click"/>
            <Button Content="Review terms…" Style="{StaticResource SecondaryButton}" Click="ReviewLegal_Click"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource CardBorder}">
        <StackPanel>
          <TextBlock Text="Bug reports (optional)" FontWeight="SemiBold"/>
          <TextBlock Text="Custom API URL (leave blank for default Render endpoint)" Margin="0,8,0,4"
                     Foreground="{StaticResource MutedBrush}" FontSize="12" TextWrapping="Wrap"/>
          <TextBox x:Name="BugReportApiBox" Padding="8" Background="#0F1419" Foreground="{StaticResource TextBrush}"
                   BorderBrush="{StaticResource BorderBrush}"/>
        </StackPanel>
      </Border>

      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
        <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="Cancel_Click"/>
        <Button Content="Save" Style="{StaticResource PrimaryButton}" Click="Save_Click"/>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</Window>
