<Window x:Class="PES3Disc.App.ReportBugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Report a bug"
        Height="420" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <TextBlock Text="Report a bug" FontSize="22" FontWeight="Bold" Margin="0,0,0,8"/>
    <TextBlock Grid.Row="1" Text="Short title and description (sent to developers)."
               Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,0,0,12"/>
    <StackPanel Grid.Row="2">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="Title"/>
        <TextBlock x:Name="TitleCount" Grid.Column="1" Foreground="{StaticResource MutedBrush}" Text="0/50"/>
      </Grid>
      <TextBox x:Name="TitleBox" MaxLength="50" Padding="8" Margin="0,4,0,12"
               Background="#0F1419" Foreground="{StaticResource TextBrush}"
               BorderBrush="{StaticResource BorderBrush}" TextChanged="TitleBox_TextChanged"/>
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="Description"/>
        <TextBlock x:Name="BodyCount" Grid.Column="1" Foreground="{StaticResource MutedBrush}" Text="0/2500"/>
      </Grid>
      <TextBox x:Name="BodyBox" MaxLength="2500" AcceptsReturn="True" TextWrapping="Wrap"
               VerticalScrollBarVisibility="Auto" MinHeight="140" Padding="8" Margin="0,4,0,0"
               Background="#0F1419" Foreground="{StaticResource TextBrush}"
               BorderBrush="{StaticResource BorderBrush}" TextChanged="BodyBox_TextChanged"/>
    </StackPanel>
    <TextBlock x:Name="StatusText" Grid.Row="3" Foreground="{StaticResource MutedBrush}"
               TextWrapping="Wrap" Margin="0,12,0,0"/>
    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="Cancel_Click"/>
      <Button x:Name="SubmitButton" Content="Submit" Style="{StaticResource PrimaryButton}" Click="Submit_Click"/>
    </StackPanel>
  </Grid>
</Window>
